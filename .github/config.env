## Shared configuration for all GitHub Actions workflows.
## Loaded via `source .github/config.env` in each workflow.

# Azure
AZURE_RESOURCE_GROUP=ai-myaacoub
AZURE_LOCATION=westus2

# App Service
API_APP_NAME=api-taxforms
UI_APP_NAME=ui-taxforms

# Bicep
BICEP_FILE=infra/main.bicep

# Runtimes
PYTHON_VERSION=3.12
NODE_VERSION=20
