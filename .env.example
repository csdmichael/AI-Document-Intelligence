# Environment variable overrides for config/azure_resources.yaml
# Only set these if you need to override the YAML defaults.

# Azure Blob Storage (override config/azure_resources.yaml -> storage)
# AZURE_STORAGE_ACCOUNT_NAME=aistoragemyaacoub
# AZURE_STORAGE_CONTAINER_NAME=tax-forms

# Azure AI Document Intelligence (override config/azure_resources.yaml -> ai_services)
# AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://001-ai-poc.cognitiveservices.azure.com/

# Azure AI Foundry (override config/azure_resources.yaml -> ai_foundry)
# AZURE_AI_FOUNDRY_ENDPOINT=https://001-ai-poc.services.ai.azure.com/api/projects/001-ai-proj

# Azure Cosmos DB (override config/azure_resources.yaml -> cosmos_db)
# AZURE_COSMOS_ENDPOINT=https://cosmos-ai-poc.documents.azure.com:443/
# AZURE_COSMOS_DATABASE=taxforms
# AZURE_COSMOS_CONTAINER=documents

# Document Intelligence model (override config/doc_intelligence.yaml -> model)
# DOC_INTELLIGENCE_MODEL_ID=prebuilt-document
# Set to your trained custom model ID after running scripts/train_custom_model.py
# DOC_INTELLIGENCE_CUSTOM_MODEL_ID=tax-form-custom-abc12345
# Comparison (OCR/read) model used with --compare flag
# DOC_INTELLIGENCE_COMPARISON_MODEL_ID=prebuilt-read

# API Settings (override config/app_settings.yaml -> api)
# API_HOST=0.0.0.0
# API_PORT=8000

# UI Settings (for local dev)
VITE_API_BASE_URL=http://localhost:8000
